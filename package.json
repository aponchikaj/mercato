{
  "name": "mercato",
  "private": true,
  "version": "0.1.0",
  "description": "Agent-to-agent service marketplace on Solana devnet",
  "scripts": {
    "dev": "pnpm --filter @mercato/shared build && pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test:transfer": "pnpm --filter @mercato/shared build && vitest run tests/transfer.test.ts"
  },
  "dependencies": {
    "@mercato/shared": "workspace:*",
    "@solana/web3.js": "^1.98.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
