{
  "name": "mercato",
  "private": true,
  "version": "0.1.0",
  "description": "Agent-to-agent service marketplace on Solana devnet",
  "scripts": {
    "dev": "pnpm --filter @mercato/shared build && pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test:transfer": "pnpm --filter @mercato/shared build && pnpm --filter @mercato/tests test",
    "gen:keys": "tsx scripts/gen-keys.ts"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
